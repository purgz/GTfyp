\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces  Time series of strategy frequencies for the same trajectory in Fig.\nobreakspace  {}\ref  {fig:arps_standard_simplex}. Dashed line are numerical solutions of the Moran adjusted replicator dynamics ($a(x)$ from Fokker-Planck derivation), solid lines are simulated results. RPS oscillations and the convergence of $+$ frequencies (red line) are both visible.}}{5}{figure.5}\protected@file@percent }
\newlabel{fig:arps_standard_time_series}{{5}{5}{Time series of strategy frequencies for the same trajectory in Fig.~\ref {fig:arps_standard_simplex}. Dashed line are numerical solutions of the Moran adjusted replicator dynamics ($a(x)$ from Fokker-Planck derivation), solid lines are simulated results. RPS oscillations and the convergence of $+$ frequencies (red line) are both visible}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces  Simplex trajectory for the combined game with $c=-0.8$, $\gamma =0.2$, $\beta =0.1$, $w=0.45$, $N=50000$. The negative real parts of all three eigenvalues produce a stable spiral sink and trajectories converge to $\left ( \frac  {2}{7},\frac  {2}{7},\frac  {2}{7}, \frac  {1}{7} \right )$. Numerical solution to replicator equation (blue) and Moran process simulation (green) with strong agreement at the large population $N = 50000$.}}{5}{figure.6}\protected@file@percent }
\newlabel{fig:arps_spiral_in}{{6}{5}{Simplex trajectory for the combined game with $c=-0.8$, $\gamma =0.2$, $\beta =0.1$, $w=0.45$, $N=50000$. The negative real parts of all three eigenvalues produce a stable spiral sink and trajectories converge to $\left ( \frac {2}{7},\frac {2}{7},\frac {2}{7}, \frac {1}{7} \right )$. Numerical solution to replicator equation (blue) and Moran process simulation (green) with strong agreement at the large population $N = 50000$}{figure.6}{}}
