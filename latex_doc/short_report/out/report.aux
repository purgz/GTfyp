\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces  Standard zero-sum RPS game ($a=0, b=1, c=-1$), $w = 0.3$. Analytical trajectory (blue), large $N$ simulation ($N=500000$, green) and small-$N$ simulation ($N=2000$, orange). The large $N$ trajectory closely follows the replicator dynamics (orbits at fixed distance from center). The small $N$ trajectory deviates due to stochastic fluctuations but still orbiting the interior fixed point $\left (\frac  {1}{3},\frac  {1}{3},\frac  {1}{3}\right )$.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:rps_standard}{{1}{2}{Standard zero-sum RPS game ($a=0, b=1, c=-1$), $w = 0.3$. Analytical trajectory (blue), large $N$ simulation ($N=500000$, green) and small-$N$ simulation ($N=2000$, orange). The large $N$ trajectory closely follows the replicator dynamics (orbits at fixed distance from center). The small $N$ trajectory deviates due to stochastic fluctuations but still orbiting the interior fixed point $\left (\frac {1}{3},\frac {1}{3},\frac {1}{3}\right )$}{figure.1}{}}
