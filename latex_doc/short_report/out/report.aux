\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces  Simplex trajectory for the combined game with standard RPS ($a=0, b=1, c=-1$), $\gamma =0.2$, $\beta =0.1$, $w=0.45$, $N=50000$. Numerical solution (blue) and Moran process simulation (green), with simulation iterations normalized by $N$ to match the ODE time steps (150 steps). The trajectory converges to the RPS plane (stable in the SD axis, eigenvalue $-\frac  {1}{15}$), and then forms periodic orbits at a fixed distance from the interior fixed point $(2/9, 2/9,2/9,1/3)$ (purely imaginary eigenvalues). Initial populations used [0.5,0.2,0.2,0.1], for R,P,S,+.}}{4}{figure.4}\protected@file@percent }
\newlabel{fig:arps_standard_simplex}{{4}{4}{Simplex trajectory for the combined game with standard RPS ($a=0, b=1, c=-1$), $\gamma =0.2$, $\beta =0.1$, $w=0.45$, $N=50000$. Numerical solution (blue) and Moran process simulation (green), with simulation iterations normalized by $N$ to match the ODE time steps (150 steps). The trajectory converges to the RPS plane (stable in the SD axis, eigenvalue $-\frac {1}{15}$), and then forms periodic orbits at a fixed distance from the interior fixed point $(2/9, 2/9,2/9,1/3)$ (purely imaginary eigenvalues). Initial populations used [0.5,0.2,0.2,0.1], for R,P,S,+}{figure.4}{}}
