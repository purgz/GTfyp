\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces  Snowdrift game population fraction time series for Local update (LU) and Moran process (MO), alongside solution to deterministic replicator equation for each process from the adjusted dynamics derived in section.\nobreakspace  {}\ref  {sec:fokker-planck}. $N = 10000, w=0.9, c=1, b=3$, Simulated large $N$ trajectories closely follow corresponding adjusted replicator dynamics. Initial population 99\% cooperators. Both processes converge to the stable mixed strategy Nash equilibrium $q^* = \frac  {1}{2}$}}{3}{figure.3}\protected@file@percent }
\newlabel{snowdrift_trajectory}{{3}{3}{Snowdrift game population fraction time series for Local update (LU) and Moran process (MO), alongside solution to deterministic replicator equation for each process from the adjusted dynamics derived in section.~\ref {sec:fokker-planck}. $N = 10000, w=0.9, c=1, b=3$, Simulated large $N$ trajectories closely follow corresponding adjusted replicator dynamics. Initial population 99\% cooperators. Both processes converge to the stable mixed strategy Nash equilibrium $q^* = \frac {1}{2}$}{figure.3}{}}
