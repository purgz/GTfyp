\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces  $\langle \Delta H_{\mathrm  {SD}} \rangle _{LU} \cdot N^2$ as a function of $N$ for the local update process at five values of $w$, with $a = 0, b = 1, c=-0.2, \gamma = 0.14, \beta = 0.3$. A drift reversal for these parameters occurs in all the cases where $w > 0$, and as $w \rightarrow 0$, the lines approach the weak selection limit (neutral evolution) of $\langle \Delta H_{\mathrm  {SD}} \rangle _{LU} \cdot N^2 = \frac  {3}{20}$. Intersections with $\langle \Delta H_{\mathrm  {SD}} \rangle _{LU} \cdot N^2$ indicate a drift reversal, and the $N$ value this occurs at is the critical population size.}}{9}{figure.8}\protected@file@percent }
\newlabel{fig:weak_selection_comparison}{{8}{9}{$\langle \Delta H_{\mathrm {SD}} \rangle _{LU} \cdot N^2$ as a function of $N$ for the local update process at five values of $w$, with $a = 0, b = 1, c=-0.2, \gamma = 0.14, \beta = 0.3$. A drift reversal for these parameters occurs in all the cases where $w > 0$, and as $w \rightarrow 0$, the lines approach the weak selection limit (neutral evolution) of $\langle \Delta H_{\mathrm {SD}} \rangle _{LU} \cdot N^2 = \frac {3}{20}$. Intersections with $\langle \Delta H_{\mathrm {SD}} \rangle _{LU} \cdot N^2$ indicate a drift reversal, and the $N$ value this occurs at is the critical population size}{figure.8}{}}
\newlabel{eq:weak_selection_rps}{{28}{9}{}{equation.6.28}{}}
