\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces  $\langle \Delta H \rangle \cdot N^2$ against $N$ for the local update process showing the SD reversal case, for each drift measure $\langle \Delta H_{SD} \rangle , \langle \Delta H_{RPS} \rangle , \text  {and} \langle \Delta H_+ \rangle $ with $\beta =0.3$, $\gamma =0.14$, $c=-0.2$, $w=0.45$. Since $N^\prime _{RPS} < N^\prime _{SD}$, the sign of the SD observable reverses first at a higher $N$. Since $N > N^\prime _{RPS}$ the RPS game converges to its interior fixed point while the fourth strategy drifts away since $N < N^\prime _{SD}$ producing the column shaped trajectory cloud in Fig.\nobreakspace  {}\ref  {drift_cases_fig}.}}{12}{figure.11}\protected@file@percent }
\newlabel{fig:sd_reversal_case}{{11}{12}{$\langle \Delta H \rangle \cdot N^2$ against $N$ for the local update process showing the SD reversal case, for each drift measure $\langle \Delta H_{SD} \rangle , \langle \Delta H_{RPS} \rangle , \text {and} \langle \Delta H_+ \rangle $ with $\beta =0.3$, $\gamma =0.14$, $c=-0.2$, $w=0.45$. Since $N^\prime _{RPS} < N^\prime _{SD}$, the sign of the SD observable reverses first at a higher $N$. Since $N > N^\prime _{RPS}$ the RPS game converges to its interior fixed point while the fourth strategy drifts away since $N < N^\prime _{SD}$ producing the column shaped trajectory cloud in Fig.~\ref {drift_cases_fig}}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces   $\langle \Delta H \rangle \cdot N^2$ against $N$ for the local update process showing the RPS reversal case with $\beta =0.24$, $\gamma =0.4$, $c=-0.8$, $w=0.45$. The exact opposite of the SD reversal case in Fig.\nobreakspace  {}\ref  {fig:sd_reversal_case}, where RPS drifts at the larger population size and SD remains stable. For $N^\prime _{SD} < N < N^\prime _{RPS}$ trajectories move towards the RPS boundaries, away from the interior fixed point, but remain stable in the SD direction resulting in the disk shaped trajectory cloud in Fig.\nobreakspace  {}\ref  {drift_cases_fig}.}}{12}{figure.12}\protected@file@percent }
\newlabel{fig:rps_reversal_case}{{12}{12}{$\langle \Delta H \rangle \cdot N^2$ against $N$ for the local update process showing the RPS reversal case with $\beta =0.24$, $\gamma =0.4$, $c=-0.8$, $w=0.45$. The exact opposite of the SD reversal case in Fig.~\ref {fig:sd_reversal_case}, where RPS drifts at the larger population size and SD remains stable. For $N^\prime _{SD} < N < N^\prime _{RPS}$ trajectories move towards the RPS boundaries, away from the interior fixed point, but remain stable in the SD direction resulting in the disk shaped trajectory cloud in Fig.~\ref {drift_cases_fig}}{figure.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces  Summary of the four drift reversal cases (table of parameter values and critical population sizes provided in the appendix). The dashed diagonal marks where $N_{SD} = N_{RPS}$, points below this line have $N_{RPS} > N_{SD}$, and the reverse for points above this line. The horizontal and vertical lines at $10^0$ indicate where the ratio $N / N_{RPS} = 1$ or $N / N_{SD} = 1$ categorising the cases, so below these lines (where the ratio is less than 1), the population size is less than the critical population size for drift reversal. The lower left region indicates the low population size case where $N << N_{RPS}, N << N_{SD}$ and there is a double drift reversal. The upper left region indicates the case where $N_{RPS} < N < N_{SD}$ and there is a drift reversal in the SD axis but not the RPS plane. The lower right region indicates the case where $N_{SD} < N < N_{RPS}$ and there is a drift reversal in RPS but not SD. The upper right region is the large population case where the trajectories follow the deterministic replicator dynamics predictions, which is convergence to the interior fixed point for each of these games ($N >> N_{RPS}, N >> N_{SD}$).}}{13}{figure.13}\protected@file@percent }
\newlabel{drift_cases_fig}{{13}{13}{Summary of the four drift reversal cases (table of parameter values and critical population sizes provided in the appendix). The dashed diagonal marks where $N_{SD} = N_{RPS}$, points below this line have $N_{RPS} > N_{SD}$, and the reverse for points above this line. The horizontal and vertical lines at $10^0$ indicate where the ratio $N / N_{RPS} = 1$ or $N / N_{SD} = 1$ categorising the cases, so below these lines (where the ratio is less than 1), the population size is less than the critical population size for drift reversal. The lower left region indicates the low population size case where $N << N_{RPS}, N << N_{SD}$ and there is a double drift reversal. The upper left region indicates the case where $N_{RPS} < N < N_{SD}$ and there is a drift reversal in the SD axis but not the RPS plane. The lower right region indicates the case where $N_{SD} < N < N_{RPS}$ and there is a drift reversal in RPS but not SD. The upper right region is the large population case where the trajectories follow the deterministic replicator dynamics predictions, which is convergence to the interior fixed point for each of these games ($N >> N_{RPS}, N >> N_{SD}$)}{figure.13}{}}
