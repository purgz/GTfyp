\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Blue - SD}}{7}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Double reversal case. Blue - SD}}{7}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Comparison of the 3 drift measures $\langle \Delta H_{SD} \rangle , \langle \Delta H_{RPS} \rangle , \text  {and} \langle \Delta H_+ \rangle $ for the local update process. $\beta = 0.3, \gamma =0.14, c=-0.2$, strong central attracting RPS case ($c > -1$) and $N_{RPS} < N_{SD}$ so SD game component reverses first, at a higher population size. This results in the vertical column point cloud where RPS fixates at the central fixed point where $x \approx y \approx z$ and $q$ drifts away from the fixed point ($N_{RPS} < N < N_{SD}$)}}{8}{}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Table of N values and corresponding ratios, depending on the values of $N_{SD}, N_{RPS}$ and $N$ when simulating trajectories, the drift reversal cases will be different, large $N$ used to show the cases above the critical population sizes where system converges to interior nash equilibrium.}}{8}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Comparison of drift measures for local update process, where $\beta = 0.4, \gamma = 0.2, c = -0.8$. Still an interior attracting RPS in large population case, however this time RPS drifts at a higher population size marked by $N^\prime _{RPS}$ so drifts to RPS boundaries whilst SD does not reverse and stays at the fixed point for SD part of the game. Results in disk shape around the central fixed point as RPS goes to boundary while SD is stable in the interior.}}{9}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces $\beta =0.1, \gamma =0.1, c=-0.8, N_{SD} = 420, N_{RPS} = 560$}}{10}{}\protected@file@percent }
